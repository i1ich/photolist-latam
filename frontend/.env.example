# Base URL of the deployed API Gateway stage (no trailing slash).
# Copy this file to `.env` (local) or `.env.production` (build) and fill in the value
# printed by `cdk deploy` (PhotolistApiStack output, ends with /prod).
#
# Example:
# VITE_API_BASE_URL=https://abc123.execute-api.sa-east-1.amazonaws.com/prod
VITE_API_BASE_URL=
